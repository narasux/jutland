  {
    name: "waterdrop",
    displayName: "水滴",
    type: "宇宙探测器",
    armaments: [
      {label: "攻击方式", value: "撞击"},
    ],
    description: "水滴是科幻小说《三体》中由三体文明制造的宇宙探测器，其对电磁波的反射率为 100％，温度处于绝对零度且绝对光滑，拥有强度高达太阳系中最坚硬的材料的百倍以上的坚硬外壳。在飞行时，水滴甚至可以毫不减速地做出违反定律的锐角转向。在末日之战中，仅单个水滴就靠撞击摧毁人类大部分的太空武装力量（共计 2008 艘恒星级战舰）。",
    author: "未知",
    links: [
      {
        name: "百度百科 - 水滴",
        url: "https://baike.baidu.com/item/%E6%B0%B4%E6%BB%B4/9086002"
      }
    ]
