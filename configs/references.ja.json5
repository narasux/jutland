  {
    "name": "Swordfish",
    "displayName": "フェアリー・ソードフィッシュ Mk I",
    "armaments": [
      {
        "label": "機銃（前方）",
        "value": "1 x 7.7mm Vickers"
      },
      {
        "label": "機銃（後方）",
        "value": "1 x 7.7mm Vickers K"
      },
      {
        "label": "魚雷",
        "value": "1 x 457mm Mark XII"
      }
    ],
    "description": "フェアリー・ソードフィッシュ Mk Iは英国海軍航空隊の艦上雷撃機である。低速の複葉機ながら優れた低速操縦性を持ち、タラント空襲とビスマルク追撃で重要な役割を果たした。本作の仕様は.303インチ機銃2挺とMark XII航空魚雷1本を搭載する。",
    "author": "不明",
    "links": [
      {
        "name": "Canada Aviation and Space Museum - Fairey Swordfish II",
        "url": "https://ingenium.ca/aviation/en/collection-highlight/fairey-swordfish-ii/"
      },
      {
        "name": "History of War - Fairey Swordfish",
        "url": "https://www.historyofwar.org/articles/weapons_fairey_swordfish.html"
      }
    ]
  },
  {
    "name": "Barracuda-II",
    "displayName": "フェアリー・バラクーダ Mk II",
    "armaments": [
      {
        "label": "機銃（後方）",
        "value": "2 x .303 in Vickers K"
      },
      {
        "label": "魚雷",
        "value": "1 x 18-inch Mark XV"
      }
    ],
    "description": "フェアリー・バラクーダ Mk IIは1943年に英国海軍航空隊へ配備された艦上雷撃・急降下爆撃機である。マーリン32を搭載した主力量産型となり、1944年のティルピッツ攻撃など主要作戦に参加した。本作では後方射撃用.303インチ・ヴィッカースK機銃2挺と18インチMark XV航空魚雷1本を搭載する。",
    "author": "不明",
    "links": [
      {
        "name": "Royal Navy - Torpedo bomber recovered from the Solent",
        "url": "https://www.royalnavy.mod.uk/news/2019/june/11/190611-torpedo-bomber-recovered-from-solent"
      },
      {
        "name": "Imperial War Museums - The Barracuda, the Navy's new torpedo bomber",
        "url": "https://www.iwm.org.uk/collections/item/object/205152671"
      }
    ]
  },
