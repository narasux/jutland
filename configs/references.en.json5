    "displayName": "T-14",
    "type": "Motor Torpedo Boat",
    "armaments": [
      {
        "label": "Main Battery",
        "value": "1x1 13mm Type 93"
      },
      {
        "label": "Torpedoes",
        "value": "2x1 450mm"
      }
    ],
    "description": "T-14 represents Japan's Type 14 motor torpedo boats, simplified wooden craft produced late in the Second World War for coastal defense. An automotive engine and austere construction allowed rapid manufacture. The small boats carried two 450 mm torpedoes and could also embark depth charges for local anti-submarine work.",
    "author": "Unknown",
    "links": [
      {
        "name": "Wikipedia — T-14",
        "url": "https://en.wikipedia.org/wiki/Motor%20torpedo%20boat"
      }
    ]
  },
